/* app.wxss - 全局样式 */

/* 颜色变量 */
page {
  --primary: #4F46E5;
  --primary-light: #818CF8;
  --primary-dark: #3730A3;
  --success: #10B981;
  --warning: #F59E0B;
  --danger: #EF4444;
  --bg: #F5F5F5;
  --card-bg: #FFFFFF;
  --text-primary: #1F2937;
  --text-secondary: #6B7280;
  --text-muted: #9CA3AF;
  --border: #E5E7EB;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用组件 */
.container {
  padding: 30rpx;
}

.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.tag {
  display: inline-block;
  background: #EEF2FF;
  color: var(--primary);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-success {
  background: #ECFDF5;
  color: var(--success);
}

.tag-warning {
  background: #FFFBEB;
  color: var(--warning);
}

/* 加载动画 */
.loading-dots {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 0;
}

.loading-dots view {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary-light);
  animation: bounce 1.4s infinite ease-in-out;
}

.loading-dots view:nth-child(1) { animation-delay: -0.32s; }
.loading-dots view:nth-child(2) { animation-delay: -0.16s; }
.loading-dots view:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state .text {
  color: var(--text-muted);
  font-size: 28rpx;
}
