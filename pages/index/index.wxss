/* pages/index/index.wxss */

/* 横幅 */
.banner {
  background: linear-gradient(135deg, #4F46E5, #7C3AED, #A855F7);
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
}

.banner-content {
  position: relative;
  z-index: 2;
}

.greeting {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.sub-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.countdown {
  font-size: 44rpx;
  font-weight: 800;
  color: #FCD34D;
  margin: 0 4rpx;
}

.banner-decoration {
  position: absolute;
  right: -20rpx;
  top: -20rpx;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.c1 {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  right: 0;
  top: 0;
}

.c2 {
  width: 140rpx;
  height: 140rpx;
  background: #fff;
  right: 80rpx;
  top: 100rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--border);
}

/* 功能网格 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.feature-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s;
}

.feature-item:active {
  transform: scale(0.97);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}

/* 学科列表 */
.subject-list {
  margin-bottom: 36rpx;
}

.subject-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.subject-item.active {
  border-color: var(--primary);
  background: #FAFAFE;
}

.subject-item:active {
  transform: scale(0.98);
}

.subject-emoji {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.subject-info {
  flex: 1;
}

.subject-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.subject-progress {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}

.subject-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

/* 资讯列表 */
.news-list {
  margin-bottom: 30rpx;
}

.news-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.news-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
}

.news-tag.policy {
  background: #EEF2FF;
  color: #4F46E5;
}

.news-tag.exp {
  background: #ECFDF5;
  color: #10B981;
}

.news-tag.tips {
  background: #FFFBEB;
  color: #F59E0B;
}

.news-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.news-date {
  font-size: 24rpx;
  color: var(--text-muted);
}
