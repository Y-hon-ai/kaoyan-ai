/* pages/practice/practice.wxss */

.practice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.header-sub {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}

.streak-badge {
  background: linear-gradient(135deg, #F59E0B, #EF4444);
  border-radius: 20rpx;
  padding: 16rpx 28rpx;
  text-align: center;
  color: #fff;
}

.streak-num {
  font-size: 40rpx;
  font-weight: 800;
}

.streak-label {
  font-size: 22rpx;
  opacity: 0.9;
}

/* 学科标签 */
.subject-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: #fff;
  color: var(--text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.tab-item.active {
  background: var(--primary);
  color: #fff;
}

/* 模式选择 */
.mode-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.mode-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.mode-card:active {
  transform: scale(0.97);
}

.mode-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.mode-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.mode-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 24rpx;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.question-type {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.type-tag {
  background: #EEF2FF;
  color: var(--primary);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.difficulty {
  font-size: 20rpx;
}

.question-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.7;
  margin-bottom: 32rpx;
}

/* 选项 */
.options-list {
  margin-bottom: 24rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.option-item.selected {
  border-color: var(--primary);
  background: #EEF2FF;
}

.option-item.correct {
  border-color: var(--success);
  background: #ECFDF5;
}

.option-item.wrong {
  border-color: var(--danger);
  background: #FEF2F2;
}

.option-label {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-label {
  background: var(--primary);
  color: #fff;
}

.option-item.correct .option-label {
  background: var(--success);
  color: #fff;
}

.option-item.wrong .option-label {
  background: var(--danger);
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.option-icon {
  margin-left: 16rpx;
  font-size: 32rpx;
}

/* 填空/简答 */
.answer-input-area {
  margin-bottom: 24rpx;
}

.answer-input {
  width: 100%;
  min-height: 200rpx;
  background: #F9FAFB;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 提交按钮 */
.submit-area {
  margin-top: 24rpx;
}

.submit-btn {
  width: 100%;
}

/* 解析区域 */
.explanation-area {
  margin-top: 32rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.result-header.correct {
  background: #ECFDF5;
}

.result-header.wrong {
  background: #FEF2F2;
}

.result-icon {
  font-size: 40rpx;
}

.result-text {
  font-size: 30rpx;
  font-weight: 600;
}

.result-header.correct .result-text {
  color: var(--success);
}

.result-header.wrong .result-text {
  color: var(--danger);
}

.explanation-card {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.explanation-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.explanation-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.ai-explain-btn {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #EEF2FF;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.ai-explain-btn:active {
  background: #E0E7FF;
}

.next-btn {
  width: 100%;
  margin-top: 16rpx;
}

/* 结果页 */
.result-page {
  padding: 40rpx 0;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.result-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 40rpx;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.result-stat {
  text-align: center;
}

.rs-num {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--primary);
}

.rs-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-actions button {
  flex: 1;
}
