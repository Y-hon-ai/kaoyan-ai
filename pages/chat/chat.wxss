/* pages/chat/chat.wxss */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F5F5;
}

/* 学科选择栏 */
.subject-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.subject-scroll {
  white-space: nowrap;
}

.subject-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
  background: #F3F4F6;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.subject-chip.active {
  background: var(--primary);
  color: #fff;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx;
  overflow-y: scroll;
}

/* 欢迎卡片 */
.welcome-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.welcome-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.welcome-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.quick-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.quick-item {
  background: #EEF2FF;
  color: var(--primary);
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  transition: all 0.2s;
}

.quick-item:active {
  background: var(--primary);
  color: #fff;
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
  gap: 16rpx;
}

.message-item.user {
  flex-direction: row-reverse;
}

.avatar {
  flex-shrink: 0;
}

.avatar-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.avatar-icon.user {
  background: linear-gradient(135deg, #10B981, #059669);
}

/* 消息气泡 */
.bubble {
  max-width: 75%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  position: relative;
  word-wrap: break-word;
  word-break: break-all;
}

.bubble.assistant {
  background: #fff;
  border-radius: 4rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bubble.user {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  color: #fff;
  border-radius: 24rpx 4rpx 24rpx 24rpx;
}

.msg-content {
  font-size: 28rpx;
  line-height: 1.7;
}

.bubble.user .msg-content {
  color: #fff;
}

/* 消息操作 */
.msg-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 4rpx 0;
}

.action-btn:active {
  color: var(--primary);
}

/* 底部占位 */
.bottom-spacer {
  height: 20rpx;
}

/* 输入区域 */
.input-area {
  background: #fff;
  border-top: 1rpx solid var(--border);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.input-field {
  flex: 1;
  background: #F3F4F6;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  max-height: 200rpx;
  min-height: 40rpx;
  line-height: 1.5;
}

.input-placeholder {
  color: var(--text-muted);
}

.send-btn {
  padding: 20rpx 32rpx;
  border-radius: 24rpx;
  background: #D1D5DB;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s;
  white-space: nowrap;
}

.send-btn.active {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
}

.send-btn:active {
  opacity: 0.85;
}

/* 快捷功能栏 */
.quick-bar {
  display: flex;
  justify-content: space-around;
  padding-top: 16rpx;
}

.quick-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 16rpx;
}

.quick-btn:active {
  color: var(--primary);
}
