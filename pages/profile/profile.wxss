/* pages/profile/profile.wxss */

.profile-card {
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.avatar-area {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
}

.user-desc {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.data-overview {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.data-item {
  flex: 1;
  text-align: center;
}

.data-num {
  font-size: 40rpx;
  font-weight: 800;
}

.data-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 6rpx;
}

.data-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.2);
}

/* 卡片行 */
.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-left {
  display: flex;
  align-items: center;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.card-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.card-value {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-top: 4rpx;
}

.card-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

/* 菜单列表 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

.menu-divider {
  height: 1rpx;
  background: var(--border);
  margin-left: 56rpx;
}

/* 分享卡片 */
.share-card {
  background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
}

.share-content {
  display: flex;
  align-items: center;
}

.share-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.share-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.share-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}
